# ============================================
# 博客系统 - Git 忽略规则
# ============================================

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
dist/
*.egg
.venv/
venv/
env/

# ---- Node ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- 构建输出 ----
front/dist/
mini/dist/

# ---- 环境变量 ----
.env
.env.local
.env.*.local

# ---- 数据库 ----
*.db
*.db-shm
*.db-wal
back/blog.db

# ---- 上传文件 ----
uploads/*
!uploads/.gitkeep
*/uploads/*

# ---- 日志 ----
logs/
*.log

# ---- IDE ----
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ---- 系统 ----
.DS_Store
Thumbs.db

# ---- Android (Capacitor) ----
mini/android/.gradle/
mini/android/build/
mini/android/app/build/
mini/android/local.properties
mini/android/capacitor.settings.gradle

# ---- 其他 ----
back/.env
copy/
front copy/
