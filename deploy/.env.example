# ---- 安全配置（务必修改！）----
SECRET_KEY=your-strong-secret-key-here-change-it
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-strong-password-here

# ---- 服务地址 ----
BASE_URL=http://your-domain.com:8000
