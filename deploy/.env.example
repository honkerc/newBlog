# ============================================
# 博客系统 - 部署环境变量
# ============================================
# 复制此文件为 .env 并修改配置:
#   cp .env.example .env
#
# 生成 SECRET_KEY:
#   openssl rand -hex 32
# ============================================

# ---- 安全配置（务必修改！）----
SECRET_KEY=your-strong-secret-key-here-change-it
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-strong-password-here

# ---- 服务地址 ----
# 生产环境使用域名（不带端口，Nginx 反向代理）
BASE_URL=http://honkerc.cn