# ============================================
# 博客后端 - Docker 镜像
# ============================================
FROM python:3.11-slim

WORKDIR /app

# 安装依赖
COPY back/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# 复制后端代码
COPY back/ .

# 创建必要目录
RUN mkdir -p uploads files logs

# 暴露端口
EXPOSE 8000

# 启动
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
